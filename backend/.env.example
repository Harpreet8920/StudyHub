PORT=5000
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=studyhub
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
# You can also use a URL-style connection string instead of DB_* values:
# DATABASE_URL=mysql://user:password@host:3306/studyhub
JWT_SECRET=replace_with_a_strong_secret
# For multiple frontend URLs, separate with commas
FRONTEND_URL=http://localhost:5173
