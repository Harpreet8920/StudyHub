{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/dist/$1"
    },
    {
      "src": "/login",
      "dest": "/dist/login.html"
    },
    {
      "src": "/signup",
      "dest": "/dist/signup.html"
    },
    {
      "src": "/dashboard",
      "dest": "/dist/dashboard.html"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/dist/assets/$1"
    }
  ]
}
